{
  "name": "vigorix",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Bilingual AI-assisted workout generator (Spanish/English) with multi-source exercise database",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "build:exercises": "node scripts/buildExerciseDatabase.mjs",
    "validate:exercises": "node scripts/validateExerciseDatabase.mjs",
    "db": "npm run build:exercises && npm run validate:exercises"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "vite": "^5.3.5"
  }
}
